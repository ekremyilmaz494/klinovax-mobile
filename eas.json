{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://klinovax.com"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "autoIncrement": true,
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://klinovax.com"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "ios": {
        "autoIncrement": "buildNumber"
      },
      "android": {
        "autoIncrement": "versionCode",
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://klinovax.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "<<KULLANICI_APPLE_ID>>",
        "ascAppId": "<<APP_STORE_CONNECT_APP_ID>>",
        "appleTeamId": "<<APPLE_TEAM_ID>>"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
